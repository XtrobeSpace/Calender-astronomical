# ─────────────────────────────────────────────────────────────
# XTROBE — Local environment variables
# Copy this file to .env, fill in your real keys.
# .env is in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# NASA NeoWs API keys — get free keys at https://api.nasa.gov
# Key 1 is tried first; Key 2 is the automatic fallback on rate-limit.
NASA_API_KEY_1=your_first_nasa_key_here
NASA_API_KEY_2=your_second_nasa_key_here
